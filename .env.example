# aeon-music-maker — environment variables.
# Copy to .env and edit. The Python CLI reads these via os.environ.

# === ComfyUI server ===
# URL of your running ComfyUI instance. Use the LAN IP if remote.
COMFYUI_URL=http://127.0.0.1:8188

# Optional: only needed if you want output to land inside an existing
# ComfyUI install. If unset, outputs go to <repo>/output/.
# COMFYUI_ROOT=/path/to/your/ComfyUI

# === Output ===
# Override where generated files land. Default: ${COMFYUI_ROOT}/output
# OUTPUT_DIR=./output

# === Binary paths (optional) ===
# Default: rely on PATH. Set these only if ffmpeg/ffprobe live elsewhere.
# FFMPEG=/usr/bin/ffmpeg
# FFPROBE=/usr/bin/ffprobe

# === Default model variant ===
# Override the default --variant when --variant is omitted on the CLI.
# Choices: xl_base (max quality, slow), xl_sft, xl_base_sft, xl_turbo, base_turbo
# ACE_DEFAULT_VARIANT=xl_base

# === Default mastering preset ===
# Override --master default. Choices: auto, off, default, edm, trap, chill, orchestral, jazz
# MASTER_DEFAULT_PRESET=auto

# === Optional: HuggingFace token ===
# Required only if downloading gated models via setup.sh / sync.sh.
# Get one from https://huggingface.co/settings/tokens
# HF_TOKEN=
